# EasyClaw port configuration — copy to .env and edit as needed.
# Shell exports always take precedence over values in this file.
# .env.local (gitignored) takes precedence over .env.
#
# Ports must be integers in range 1024–65535.
# Run scripts/check-ports.sh to find conflicts.

NEMOCLAW_GATEWAY_PORT=8080
NEMOCLAW_DASHBOARD_PORT=18789
NEMOCLAW_VLLM_PORT=8000
NEMOCLAW_OLLAMA_PORT=11434
